// Función para obtener la IP más relevante (Prioridad tun0)
char* get_nexus_ip() {
    int fd; struct ifreq ifr; static char ip[16];
    const char* ifaces[] = {"tun0", "wlan0", "eth0"};
    fd = socket(AF_INET, SOCK_DGRAM, 0);
    for(int i=0; i<3; i++) {
        strncpy(ifr.ifr_name, ifaces[i], IFNAMSIZ-1);
        if (ioctl(fd, SIOCGIFADDR, &ifr) == 0) {
            strcpy(ip, inet_ntoa(((struct sockaddr_in *)&ifr.ifr_addr)->sin_addr));
            close(fd); return ip;
        }
    }
    close(fd); return "127.0.0.1";
}

