#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    char slot[5] = "";
    char target_partition[100];
    char command[256];
    const char* patched_img = "/sdcard/Download/new-boot.img";

    // 1. Determinar el slot opuesto (Inactivo)
    FILE* pipe = popen("getprop ro.boot.slot_suffix", "r");
    if (pipe && fgets(slot, sizeof(slot), pipe)) {
        slot[strcspn(slot, "\n")] = 0;
        pclose(pipe);
    }

    if (strlen(slot) > 0) {
        // Si estamos en _a, flasheamos en _b y viceversa
        const char* target_slot = (strcmp(slot, "_a") == 0) ? "_b" : "_a";
        snprintf(target_partition, sizeof(target_partition), "/dev/block/by-name/boot%s", target_slot);
        printf("Dispositivo A/B. Flasheando en slot inactivo: %s\n", target_partition);
    } else {
        // Dispositivo Legacy: Solo hay una partición boot
        snprintf(target_partition, sizeof(target_partition), "/dev/block/by-name/boot");
        printf("Dispositivo Legacy. Flasheando en: %s\n", target_partition);
    }

    // 2. Comando DD para flashear
    // 'status=progress' permite ver el avance en la terminal
    snprintf(command, sizeof(command), "su -c 'dd if=%s of=%s status=progress'", patched_img, target_partition);

    printf("¡PELIGRO! Escribiendo en partición de arranque...\n");
    
    if (system(command) == 0) {
        printf("Flasheo completado. Reinicia para aplicar cambios.\n");
        // Opcional: su -c 'reboot'
    } else {
        fprintf(stderr, "Error crítico durante el flasheo.\n");
    }

    return 0;
}
