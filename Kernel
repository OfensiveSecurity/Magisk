#include <sys/socket.h>
#include <sys/ioctl.h>
#include <net/if.h>
#include <unistd.h>
#include <stdio.h>
#include <errno.h>

// Función para verificar si tenemos acceso real a la interfaz
int check_wifi_raw_support(const char* iface) {
    int sock = socket(AF_INET, SOCK_DGRAM, 0);
    struct ifreq ifr;
    
    if (sock < 0) return -1;

    strncpy(ifr.ifr_name, iface, IFNAMSIZ);
    
    // Intentamos obtener los flags de la interfaz
    if (ioctl(sock, SIOCGIFFLAGS, &ifr) < 0) {
        if (errno == EACCES || errno == EPERM) {
            printf("[-] Error: Acceso denegado al hardware. ¿Tienes Root real?\n");
        }
        close(sock);
        return -1;
    }

    close(sock);
    return 0; // Tenemos acceso básico
}
